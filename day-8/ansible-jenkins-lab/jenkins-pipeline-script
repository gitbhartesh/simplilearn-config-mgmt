pipeline {
    agent any
    stages {
        stage('Clone Repository') {
            steps {
                git branch: 'main', credentialsId: 'bhartesh-git', url: 'git@github.com:gitbhartesh/simplilearn-ansible-jenkins-lab.git'
            }
        }
        stage('Run Ansible Playbook') {
            steps {
                sh 'ansible-playbook -i hosts install_apache.yml'
            }
        }
    }
}